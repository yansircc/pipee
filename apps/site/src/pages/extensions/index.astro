---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExtensionCard from "../../components/ExtensionCard.astro";
import { extensions } from "../../data/product";
---
<BaseLayout title="Extensions — Pipee" description="浏览可以按需安装到 Pi 的 Extensions。"><div class="page"><section class="content-hero pad"><span class="eyebrow">Extension directory</span><div><h1>按需扩展你的 Pi。</h1><p>Extensions 是可选能力，不是 Pipee 的运行依赖。这里仅列出经过官方验证并推荐使用的项目。</p></div></section><section class="directory pad"><div class="directory-head"><h2>Extensions</h2><span>{extensions.length} 个项目</span></div><div class="list">{extensions.map((extension)=><ExtensionCard extension={extension}/>)}</div><p class="note">所有 Extension 均独立安装。只安装工作中真正需要的能力。</p></section><section class="developer pad"><div><span class="eyebrow">For developers</span><h2>用 Pi Extension API<br/>构建新的能力。</h2></div><a class="button" href="/developers">查看开发文档 <span>→</span></a></section></div></BaseLayout>
<style>.directory{padding-bottom:110px;padding-top:72px}.directory-head{align-items:baseline;border-bottom:1px solid var(--ink);display:flex;justify-content:space-between;margin-bottom:14px;padding-bottom:15px}.directory-head h2{font-size:22px;margin:0}.directory-head span{color:var(--dim);font:700 9px var(--mono);text-transform:uppercase}.list{display:grid;gap:10px}.note{color:var(--dim);font-size:11px;margin:20px 0 0}.developer{align-items:end;background:#dedbd1;display:flex;justify-content:space-between;padding-bottom:90px;padding-top:90px}.developer h2{font-size:clamp(38px,5vw,64px);letter-spacing:-.06em;line-height:1;margin:32px 0 0}@media(max-width:650px){.directory{padding-bottom:80px;padding-top:55px}.developer{align-items:flex-start;flex-direction:column;gap:40px}}</style>
