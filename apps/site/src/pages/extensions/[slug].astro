---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { extensions } from "../../data/product";
export function getStaticPaths(){return extensions.map((extension)=>({params:{slug:extension.slug},props:{extension}}))}
interface Props { extension: (typeof extensions)[number] }
const { extension } = Astro.props;
const install = `pi install npm:${extension.packageName}`;
---
<BaseLayout title={`${extension.name} Extension — Pipee`} description={extension.summary}><div class="page detail"><section class="detail-hero pad"><div class="breadcrumbs"><a href="/extensions">Extensions</a><span>/</span><span>{extension.name}</span></div><div class="title-row"><span class="detail-icon" style={`--accent:${extension.color}`}>{extension.mark}</span><div><div class="badges">{extension.recommended&&<span>✓ 官方推荐</span>}<span>{extension.category}</span></div><h1>{extension.name}</h1><p>{extension.summary}</p></div></div></section><section class="detail-content pad"><article><span class="eyebrow">About</span><h2>一项独立安装的<br/>Pi Extension。</h2><p>它基于 Pi Extension API 运行。Pipee 只负责展示说明和可选的 Web Surface；安装、启用和运行时事实仍由 Pi 拥有。</p></article><aside><div class="facts"><div><span>Package</span><code>{extension.packageName}</code></div><div><span>Version</span><strong>{extension.version}</strong></div><div><span>Runtime</span><strong>Pi Extension</strong></div></div><div class="detail-install"><span>安装到 Pi</span><code>{install}</code><button type="button" data-copy={install}>复制命令</button></div></aside></section><section class="more pad"><p>Extension 是可选能力。只安装你需要的项目。</p><a class="button" href="/extensions">返回 Extensions <span>→</span></a></section></div></BaseLayout>
<script>document.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((button)=>button.addEventListener("click",async()=>{await navigator.clipboard.writeText(button.dataset.copy??"");button.textContent="已复制 ✓";window.setTimeout(()=>button.textContent="复制命令",1400)}));</script>
<style>.detail-hero{border-bottom:1px solid var(--line);padding-bottom:78px;padding-top:34px}.breadcrumbs{color:var(--dim);display:flex;font:700 9px var(--mono);gap:10px}.title-row{align-items:center;display:grid;gap:38px;grid-template-columns:76px 1fr;margin-top:68px}.detail-icon{align-items:center;background:var(--accent);border-radius:16px;color:#fff;display:flex;font:40px var(--serif);height:76px;justify-content:center;width:76px}.badges{display:flex;gap:8px}.badges span{border:1px solid var(--line);border-radius:999px;color:var(--muted);font:700 8px var(--mono);padding:7px 10px}.title-row h1{font-size:clamp(62px,8vw,104px);letter-spacing:-.075em;line-height:.9;margin:22px 0 18px}.title-row p{color:var(--muted);font-size:16px;line-height:1.7;margin:0;max-width:680px}.detail-content{display:grid;gap:100px;grid-template-columns:1fr 1fr;padding-bottom:110px;padding-top:95px}.detail-content article h2{font-size:clamp(40px,5vw,62px);letter-spacing:-.06em;line-height:1;margin:32px 0 24px}.detail-content article p{color:var(--muted);font-size:14px;line-height:1.9;max-width:520px}.detail-content aside{align-self:start;background:#fff;border:1px solid var(--line);border-radius:10px;padding:24px}.facts{display:grid;grid-template-columns:2fr 1fr 1fr}.facts div{border-right:1px solid var(--line);min-width:0;padding:5px 15px 18px}.facts div:first-child{padding-left:0}.facts div:last-child{border:0;padding-right:0}.facts span,.detail-install>span{color:var(--dim);display:block;font:700 8px var(--mono);letter-spacing:.08em;margin-bottom:10px;text-transform:uppercase}.facts code,.facts strong{font:700 9px var(--mono);overflow-wrap:anywhere}.detail-install{border-top:1px solid var(--line);padding-top:22px}.detail-install code{background:#eeeeeb;border-radius:6px;display:block;font:700 11px/1.5 var(--mono);overflow-wrap:anywhere;padding:14px}.detail-install button{background:transparent;border:0;color:var(--blue);cursor:pointer;font-size:10px;font-weight:700;margin-top:12px;padding:0}.more{align-items:center;background:#eeeeeb;display:flex;justify-content:space-between;padding-bottom:62px;padding-top:62px}.more p{color:var(--muted);font-size:13px}@media(max-width:720px){.title-row{align-items:start;grid-template-columns:1fr;margin-top:45px}.detail-content{gap:50px;grid-template-columns:1fr;padding-bottom:75px;padding-top:70px}.facts{grid-template-columns:1fr 1fr}.facts div:first-child{border-bottom:1px solid var(--line);border-right:0;grid-column:1/-1;margin-bottom:16px;padding-right:0}.more{align-items:flex-start;flex-direction:column;gap:22px}}</style>
