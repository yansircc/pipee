---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="页面不存在 — Pipee" description="找不到这个 Pipee 页面。"><section class="not-found pad"><span class="eyebrow">404</span><h1>这里没有页面。</h1><p>地址可能已经变化，或从未属于 Pipee。</p><a class="button dark" href="/">返回首页 <span>→</span></a></section></BaseLayout>
<style>.not-found{min-height:70vh;padding-bottom:120px;padding-top:120px}.not-found h1{font-size:clamp(58px,9vw,120px);letter-spacing:-.08em;line-height:.9;margin:40px 0 25px}.not-found p{color:var(--muted);font-size:15px;margin-bottom:40px}</style>
