---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstallBox from "../components/InstallBox.astro";
import { product } from "../data/product";
---
<BaseLayout title="Pipee — 在浏览器里使用 Pi" description="全局安装 Pipee，在浏览器里使用和管理你的 Pi Session。">
  <div class="page home">
    <section class="hero pad" id="install">
      <div class="hero-copy"><span class="eyebrow">Web UI for Pi</span><h1>在浏览器里，<br />使用你的 <em>Pi。</em></h1><p>Pipee 把真实的 Pi Session 带进浏览器。它不是另一套 Agent，也不要求你安装任何特定 Extension。</p></div>
      <div class="install-panel"><div class="install-heading"><span>推荐安装方式</span><strong>全局安装</strong></div><InstallBox /><p>全局安装后，在任意项目目录运行：</p><div class="run-command"><code>{product.cli}</code><span>启动本地 Web UI</span></div><a class="button dark" href="/docs">查看完整安装文档 <span>→</span></a></div>
    </section>
    <section class="quickstart pad"><div class="section-title"><span class="eyebrow">Quick start</span><h2>安装，然后打开。</h2></div><ol><li><span>01</span><strong>全局安装 Pipee</strong><p>一次安装，之后可以从任意项目目录启动。</p></li><li><span>02</span><strong>运行 <code>{product.cli}</code></strong><p>Pipee 启动本地服务，并连接当前 Pi 环境。</p></li><li><span>03</span><strong>在浏览器中工作</strong><p>继续已有 Session，查看运行过程，需要时随时接管。</p></li></ol></section>
    <section class="boundary pad"><span class="eyebrow">What Pipee is</span><div><h2>Pi 是 Agent Runtime。<br />Pipee 是它的 Web UI。</h2><p>Pipee 不替代 Pi，也不依赖特定 Extension。Extensions 只是按需安装的可选能力。</p><div class="links"><a href="/extensions">浏览 Extensions →</a><a href="/developers">开发 Extension →</a></div></div></section>
  </div>
</BaseLayout>
<style>
  .hero{align-items:center;display:grid;gap:clamp(56px,8vw,110px);grid-template-columns:minmax(0,1.08fr) minmax(390px,.92fr);min-height:calc(100vh - 64px);padding-bottom:72px;padding-top:72px}.hero h1{font-size:clamp(64px,7.6vw,104px);letter-spacing:-.078em;line-height:.91;margin:34px 0 30px}.hero h1 em{color:var(--blue);font-style:normal;font-weight:650}.hero-copy>p{color:var(--muted);font-size:17px;line-height:1.75;margin:0;max-width:610px}.install-panel{background:#eeeeeb;border:1px solid var(--line);border-radius:12px;padding:24px}.install-heading{align-items:baseline;display:flex;justify-content:space-between;margin-bottom:22px}.install-heading span{color:var(--dim);font:700 9px var(--mono);letter-spacing:.1em;text-transform:uppercase}.install-heading strong{font-size:14px}.install-panel :global(.install-box){max-width:none}.install-panel>p{color:var(--muted);font-size:11px;line-height:1.6;margin:17px 0 8px}.run-command{align-items:center;background:#deded9;border-radius:7px;display:flex;justify-content:space-between;margin-bottom:20px;padding:13px 14px}.run-command code{font:700 12px var(--mono)}.run-command span{color:var(--dim);font-size:10px}.install-panel .button{width:100%}.quickstart{border-top:1px solid var(--line);padding-bottom:110px;padding-top:110px}.section-title{align-items:end;display:flex;justify-content:space-between;margin-bottom:52px}.section-title h2{font-size:clamp(38px,5vw,68px);letter-spacing:-.065em;margin:0}.quickstart ol{border-top:1px solid var(--ink);display:grid;grid-template-columns:repeat(3,1fr);list-style:none;margin:0;padding:0}.quickstart li{border-bottom:1px solid var(--ink);border-right:1px solid var(--ink);padding:28px 30px 34px}.quickstart li:last-child{border-right:0}.quickstart li>span{display:block;font:700 9px var(--mono);margin-bottom:54px}.quickstart li strong{display:block;font-size:22px;letter-spacing:-.03em}.quickstart li p{color:var(--muted);font-size:13px;line-height:1.7;margin:13px 0 0}.boundary{background:var(--ink);color:#fff;display:grid;gap:60px;grid-template-columns:.7fr 1.3fr;padding-bottom:110px;padding-top:110px}.boundary h2{font-size:clamp(42px,5.5vw,76px);letter-spacing:-.065em;line-height:.98;margin:0}.boundary p{color:#aaa9a2;font-size:14px;line-height:1.8;margin:28px 0 40px;max-width:560px}.links{display:flex;gap:35px}.links a{border-bottom:1px solid;font-size:12px;font-weight:750;padding-bottom:8px}@media(max-width:850px){.hero{grid-template-columns:1fr;min-height:auto}.section-title{align-items:start;flex-direction:column;gap:28px}}@media(max-width:650px){.hero{gap:48px;padding-bottom:64px;padding-top:58px}.hero h1{font-size:clamp(56px,17vw,82px)}.hero-copy>p{font-size:15px}.install-panel{margin-left:calc(var(--gutter)*-.35);margin-right:calc(var(--gutter)*-.35);padding:20px}.quickstart{padding-bottom:78px;padding-top:78px}.quickstart ol,.boundary{grid-template-columns:1fr}.quickstart li{border-right:0}.quickstart li>span{margin-bottom:28px}.boundary{gap:40px}.links{align-items:flex-start;flex-direction:column;gap:22px}}
</style>
