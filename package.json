{
  "name": "@yansircc/pi-suite-workspace",
  "version": "0.5.7",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yansircc/pi-suite.git"
  },
  "homepage": "https://github.com/yansircc/pi-suite#readme",
  "bugs": {
    "url": "https://github.com/yansircc/pi-suite/issues"
  },
  "scripts": {
    "prepare": "effect-tsgo patch --typescript-package typescript",
    "check:workspace": "node tooling/release/verify-workspace.mjs",
    "test:release": "node --test tooling/release/*.test.mjs",
    "build:candidates": "node tooling/release/build-candidates.mjs",
    "verify:candidates": "node tooling/release/verify-candidates.mjs",
    "verify:consumers": "node tooling/release/verify-consumers.mjs",
    "verify:platform": "node tooling/release/verify-platform.mjs",
    "verify:chrome-candidate": "node tooling/release/verify-chrome-candidate.mjs",
    "publish:candidates": "node tooling/release/publish-candidates.mjs",
    "verify:registry": "node tooling/release/verify-registry.mjs",
    "verify:packages": "pnpm -r --if-present run verify",
    "verify": "pnpm run check:workspace && pnpm run test:release && pnpm run verify:packages",
    "release:verify": "pnpm run build:candidates && pnpm run verify:candidates && pnpm run verify:consumers && pnpm run verify:chrome-candidate && pnpm run verify:platform"
  },
  "devDependencies": {
    "@effect/tsgo": "catalog:",
    "acorn": "8.15.0",
    "cross-spawn": "7.0.6",
    "tar": "7.5.20",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@11.13.1"
}
