{
  "name": "@yansircc/pi-loop",
  "version": "0.5.7",
  "description": "Effect-based temporal loops for Pi",
  "keywords": [
    "cron",
    "pi-extension",
    "pi-package",
    "scheduler"
  ],
  "homepage": "https://github.com/yansircc/pi-suite/tree/main/extensions/loop#readme",
  "bugs": {
    "url": "https://github.com/yansircc/pi-suite/issues"
  },
  "license": "MIT",
  "author": "Yansir <markyan@foxmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yansircc/pi-suite.git",
    "directory": "extensions/loop"
  },
  "files": [
    "dist/pi"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "verify": "pnpm run repo:quality && pnpm run pi:verify",
    "repo:quality": "vp run quality",
    "test": "vp test",
    "pi:build": "node ../../tooling/pi-extension/build.mjs .",
    "pi:bundle-check": "node ../../tooling/pi-extension/verify-distribution.mjs . bundle",
    "pi:distribution-check": "node ../../tooling/pi-extension/verify-distribution.mjs . package",
    "pi:verify": "pnpm run pi:build && pnpm run pi:bundle-check",
    "pi:domain-check": "node scripts/domain/verify-extension.mjs",
    "release:archive-check": "node ../../tooling/pi-extension/verify-distribution.mjs . archive",
    "release:platform-check": "node ../../tooling/pi-extension/verify-distribution.mjs . platform"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@pi-suite/companion-contracts": "workspace:*",
    "@pi-suite/extension-kit": "workspace:*",
    "@pi-suite/host-runtime": "workspace:*",
    "@sinclair/typebox": "0.34.41",
    "@types/cross-spawn": "catalog:",
    "@types/node": "22.20.1",
    "@yansircc/effect-scan": "catalog:",
    "cross-spawn": "7.0.6",
    "effect": "catalog:",
    "jiti": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.19.0 || >=24.11.0"
  },
  "packageManager": "pnpm@11.13.1",
  "pi": {
    "extensions": [
      "./dist/pi/extension.js"
    ]
  }
}
