{
  "name": "@yansircc/pi-weixin",
  "version": "0.0.6",
  "description": "Weixin iLink bridge for Pi sessions hosted by pi-web",
  "keywords": [
    "ilink",
    "pi-extension",
    "pi-package",
    "weixin"
  ],
  "homepage": "https://github.com/yansircc/pi-suite/tree/main/extensions/weixin#readme",
  "bugs": {
    "url": "https://github.com/yansircc/pi-suite/issues"
  },
  "license": "MIT",
  "author": "yansircc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yansircc/pi-suite.git",
    "directory": "extensions/weixin"
  },
  "files": [
    "dist/pi",
    "dist/web"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "vp check",
    "effect:scan": "vp run ci:effect",
    "test": "vp test",
    "typecheck": "vp run ci:typecheck",
    "verify": "pnpm run repo:verify && pnpm run pi:verify",
    "repo:verify": "vp run ci:verify",
    "pi:web-build": "node ../../tooling/pi-extension/build-web.mjs .",
    "pi:build": "pnpm run pi:web-build && node ../../tooling/pi-extension/build.mjs .",
    "pi:bundle-check": "node ../../tooling/pi-extension/verify-distribution.mjs . bundle",
    "pi:distribution-check": "node ../../tooling/pi-extension/verify-distribution.mjs . package",
    "pi:verify": "pnpm run pi:build && pnpm run pi:bundle-check",
    "pi:domain-check": "node scripts/domain/verify-extension.mjs",
    "release:archive-check": "node ../../tooling/pi-extension/verify-distribution.mjs . archive",
    "release:platform-check": "node ../../tooling/pi-extension/verify-distribution.mjs . platform"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@pi-suite/companion-contracts": "workspace:*",
    "@pi-suite/extension-kit": "workspace:*",
    "@pi-suite/host-runtime": "workspace:*",
    "@sinclair/typebox": "0.34.41",
    "@types/cross-spawn": "catalog:",
    "@types/node": "^25.0.0",
    "@types/qrcode": "^1.5.6",
    "@yansircc/effect-scan": "catalog:",
    "cross-spawn": "7.0.6",
    "effect": "catalog:",
    "jiti": "catalog:",
    "json-bigint": "1.0.0",
    "qrcode": "^1.5.4",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.19.0 || >=24.11.0"
  },
  "packageManager": "pnpm@11.13.1",
  "ilink": {
    "appId": "bot",
    "clientVersion": "2.4.6"
  },
  "pi": {
    "extensions": [
      "./dist/pi/extension.js"
    ]
  },
  "piSuite": {
    "web": {
      "contract": "pi-suite/web-surface@1",
      "document": "./dist/web/index.html",
      "title": "微信桥接"
    }
  }
}
